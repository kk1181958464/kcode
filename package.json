{
  "name": "kcode",
  "version": "0.1.0",
  "private": true,
  "description": "A multi-provider desktop coding agent",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json",
    "start": "electron .",
    "typecheck": "tsc -b --pretty false && tsc -p electron/tsconfig.json --pretty false",
    "test": "tsx --test electron/*.test.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "diff": "^9.0.0",
    "electron": "latest",
    "electron-updater": "^6.8.9",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "vite": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^3.0.2",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "tsx": "latest",
    "typescript": "latest",
    "wait-on": "latest"
  }
}
