{
  "name": "kcode",
  "version": "0.1.2",
  "private": true,
  "author": "KCode",
  "description": "A multi-provider desktop coding agent",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json",
    "start": "electron .",
    "typecheck": "tsc -b --pretty false && tsc -p electron/tsconfig.json --pretty false",
    "test": "tsx --test electron/*.test.ts",
    "icons": "node scripts/generate-icons.mjs",
    "dist:win": "npm run icons && npm run build && electron-builder --win nsis --publish never",
    "release:win": "npm run dist:win -- --publish always"
  },
  "build": {
    "appId": "com.kcode.desktop",
    "productName": "KCode",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "80f2649b913c028210842f9ffd752179.png",
        "to": "80f2649b913c028210842f9ffd752179.png"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "artifactName": "KCode-${version}-setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KCode"
    },
    "publish": {
      "provider": "github",
      "owner": "kk1181958464",
      "repo": "kcode",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "diff": "^9.0.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "vite": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "electron": "latest",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^3.0.2",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "tsx": "latest",
    "typescript": "latest",
    "wait-on": "latest"
  }
}
